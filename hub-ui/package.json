{
	"name": "hub-ui",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --watch & bun --hot src/index.ts",
		"typecheck": "tsc --noEmit",
		"build": "tsc --noEmit && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --public-path=/ --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun serve.ts",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.0",
		"antd": "^6.1.0",
		"i18next": "^25.7.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-i18next": "^16.5.0",
		"react-router-dom": "^7.11.0",
		"vetchium-specs": "file:../specs/typespec"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"prettier": "^3.7.4",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.4"
	}
}
