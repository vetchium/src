# Copy to staging/.env and fill in. staging/.env is git-ignored.
# docker compose auto-loads it (up.sh / down.sh run from this directory).
# This file lists EVERY key the stack needs; real secrets go in staging/.env.

# Image tag to pull from ghcr.io/vetchium/* (build-push.sh publishes :staging).
STAGING_TAG=staging

# ── Initial admin (bootstrapped once on first `up`) ──────────────────────────
STAGING_ADMIN_EMAIL=admin@vetchium.com
STAGING_ADMIN_PASSWORD=change-me

# ── Datastore secrets ────────────────────────────────────────────────────────
# Postgres password (all DBs + every service connection string use it).
DB_PASSWORD=change-me
# Object storage (LocalStack) credentials.
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# ── Email ────────────────────────────────────────────────────────────────────
# The stack runs its own private SMTP server (service: mailserver). Apps send to
# it unauthenticated over the internal network; it delivers mail outbound.
SMTP_FROM_ADDRESS=noreply@vetchium.com
SMTP_FROM_NAME=Vetchium
# Outbound delivery. Leave the smarthost BLANK for direct-to-MX — but note mail
# from a residential/laptop IP is usually rejected or spam-foldered. For reliable
# delivery, relay through an upstream SMTP you trust (your mail server / provider);
# its password is the main email secret:
SMTP_SMARTHOST_ADDRESS=
SMTP_SMARTHOST_PORT=587
SMTP_SMARTHOST_USER=
SMTP_SMARTHOST_PASSWORD=
