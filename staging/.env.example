# Copy to staging/.env and fill in. staging/.env is git-ignored.
# docker compose auto-loads it (up.sh / down.sh run from this directory).
# This file lists EVERY key the stack needs; real secrets go in staging/.env.

# Image tag to pull from ghcr.io/vetchium/* (build-push.sh publishes :staging).
STAGING_TAG=staging

# ── Initial admin (bootstrapped once on first `up`) ──────────────────────────
STAGING_ADMIN_EMAIL=admin@vetchium.com
STAGING_ADMIN_PASSWORD=change-me

# ── Datastore secrets ────────────────────────────────────────────────────────
# Postgres password (all DBs + every service connection string use it).
DB_PASSWORD=change-me
# Object storage = Garage (per-region S3). The access key MUST be Garage-format:
# "GK" + 24 hex chars; the secret is 64 hex chars. Generate with:
#   echo "S3_ACCESS_KEY_ID=GK$(openssl rand -hex 12)"
#   echo "S3_SECRET_ACCESS_KEY=$(openssl rand -hex 32)"
S3_ACCESS_KEY_ID=GK00000000000000000000000000
S3_SECRET_ACCESS_KEY=change-me
# Garage inter-node RPC secret (64 hex):  openssl rand -hex 32
GARAGE_RPC_SECRET=change-me

# ── Email ────────────────────────────────────────────────────────────────────
# Email is captured by an in-stack Mailpit (service: mailpit) — apps send to it
# unauthenticated over the internal network (SMTP on 1025) and nothing is
# delivered outbound. Read captured mail at the Mailpit web UI on host port 8025.
# (Direct outbound SMTP to Gmail etc. does not work reliably through the
# Cloudflare tunnel / from this host, so there is no real mail server.)
SMTP_FROM_ADDRESS=noreply@vetchium.com
SMTP_FROM_NAME=Vetchium
