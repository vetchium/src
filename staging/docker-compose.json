				"test": ["CMD-SHELL", "wget -qO- http://127.0.0.1/health || exit 1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"vm-ind1": {
			"image": "nginx:alpine",
