{
	"x-comment": "Production-like staging stack — 4-VM topology on one host. All app images are PULLED from ghcr.io/vetchium/*:${STAGING_TAG} (no build:). No dev-seed: one superadmin is bootstrapped from STAGING_ADMIN_*. Email is captured by a 'mailpit' service (SMTP on 1025, web UI on host port 8025) instead of being delivered outbound — direct SMTP to Gmail through the Cloudflare tunnel is not reliable from this host. Object storage is a single-node Garage instance per region (garage-ind1/usa1/deu1). All secrets (DB_PASSWORD, S3 keys, GARAGE_RPC_SECRET, admin creds) come from staging/.env. UIs are static nginx builds (gzip). The single dev api-lb is split into four per-VM nginx front doors. A Cloudflare tunnel (cloudflared/config.yml) maps *-staging.vetchium.com to host ports 8091-8097. Run via up.sh/down.sh (which load staging/.env). See staging/README.md.",
	"services": {
		"global-db": {
			"image": "postgres:17-alpine",
			"environment": {
				"POSTGRES_DB": "vetchium_global",
				"POSTGRES_USER": "vetchium",
				"POSTGRES_PASSWORD": "${DB_PASSWORD}"
			},
			"volumes": ["./data/global-db:/var/lib/postgresql/data"],
			"healthcheck": {
				"test": ["CMD-SHELL", "pg_isready -U vetchium -d vetchium_global"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"regional-db-ind1": {
			"image": "postgres:17-alpine",
			"environment": {
				"POSTGRES_DB": "vetchium_ind1",
				"POSTGRES_USER": "vetchium",
				"POSTGRES_PASSWORD": "${DB_PASSWORD}"
			},
			"volumes": ["./data/regional-ind1:/var/lib/postgresql/data"],
			"healthcheck": {
				"test": ["CMD-SHELL", "pg_isready -U vetchium -d vetchium_ind1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"regional-db-usa1": {
			"image": "postgres:17-alpine",
			"environment": {
				"POSTGRES_DB": "vetchium_usa1",
				"POSTGRES_USER": "vetchium",
				"POSTGRES_PASSWORD": "${DB_PASSWORD}"
			},
			"volumes": ["./data/regional-usa1:/var/lib/postgresql/data"],
			"healthcheck": {
				"test": ["CMD-SHELL", "pg_isready -U vetchium -d vetchium_usa1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"regional-db-deu1": {
			"image": "postgres:17-alpine",
			"environment": {
				"POSTGRES_DB": "vetchium_deu1",
				"POSTGRES_USER": "vetchium",
				"POSTGRES_PASSWORD": "${DB_PASSWORD}"
			},
			"volumes": ["./data/regional-deu1:/var/lib/postgresql/data"],
			"healthcheck": {
				"test": ["CMD-SHELL", "pg_isready -U vetchium -d vetchium_deu1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"mailpit": {
			"image": "axllent/mailpit:latest",
			"restart": "unless-stopped",
			"ports": ["8025:8025", "1025:1025"],
			"environment": {
				"MP_SMTP_AUTH_ACCEPT_ANY": "true",
				"MP_SMTP_AUTH_ALLOW_INSECURE": "true"
			}
		},
		"garage-ind1": {
			"image": "dxflrs/garage:v1.0.1",
			"restart": "unless-stopped",
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}"
			},
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-ind1/meta:/var/lib/garage/meta",
				"./data/garage-ind1/data:/var/lib/garage/data"
			]
		},
		"garage-usa1": {
			"image": "dxflrs/garage:v1.0.1",
			"restart": "unless-stopped",
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}"
			},
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-usa1/meta:/var/lib/garage/meta",
				"./data/garage-usa1/data:/var/lib/garage/data"
			]
		},
		"garage-deu1": {
			"image": "dxflrs/garage:v1.0.1",
			"restart": "unless-stopped",
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}"
			},
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-deu1/meta:/var/lib/garage/meta",
				"./data/garage-deu1/data:/var/lib/garage/data"
			]
		},
		"garage-init-ind1": {
			"image": "ghcr.io/vetchium/garage-init:${STAGING_TAG:-staging}",
			"network_mode": "service:garage-ind1",
			"depends_on": { "garage-ind1": { "condition": "service_started" } },
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-ind1/meta:/var/lib/garage/meta"
			],
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}",
				"S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID}",
				"S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY}",
				"BUCKETS": "vetchium-ind1 vetchium-global"
			}
		},
		"garage-init-usa1": {
			"image": "ghcr.io/vetchium/garage-init:${STAGING_TAG:-staging}",
			"network_mode": "service:garage-usa1",
			"depends_on": { "garage-usa1": { "condition": "service_started" } },
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-usa1/meta:/var/lib/garage/meta"
			],
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}",
				"S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID}",
				"S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY}",
				"BUCKETS": "vetchium-usa1"
			}
		},
		"garage-init-deu1": {
			"image": "ghcr.io/vetchium/garage-init:${STAGING_TAG:-staging}",
			"network_mode": "service:garage-deu1",
			"depends_on": { "garage-deu1": { "condition": "service_started" } },
			"volumes": [
				"./garage/garage.toml:/etc/garage.toml:ro",
				"./data/garage-deu1/meta:/var/lib/garage/meta"
			],
			"environment": {
				"GARAGE_RPC_SECRET": "${GARAGE_RPC_SECRET:?set GARAGE_RPC_SECRET in staging/.env}",
				"S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID}",
				"S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY}",
				"BUCKETS": "vetchium-deu1"
			}
		},
		"migrate-global": {
			"image": "ghcr.io/vetchium/migrate:${STAGING_TAG:-staging}",
			"depends_on": { "global-db": { "condition": "service_healthy" } },
			"command": [
				"-dir",
				"/migrations/global",
				"postgres",
				"postgres://vetchium:${DB_PASSWORD}@global-db:5432/vetchium_global?sslmode=disable",
				"up"
			]
		},
		"migrate-ind1": {
			"image": "ghcr.io/vetchium/migrate:${STAGING_TAG:-staging}",
			"depends_on": { "regional-db-ind1": { "condition": "service_healthy" } },
			"command": [
				"-dir",
				"/migrations/regional",
				"postgres",
				"postgres://vetchium:${DB_PASSWORD}@regional-db-ind1:5432/vetchium_ind1?sslmode=disable",
				"up"
			]
		},
		"migrate-usa1": {
			"image": "ghcr.io/vetchium/migrate:${STAGING_TAG:-staging}",
			"depends_on": { "regional-db-usa1": { "condition": "service_healthy" } },
			"command": [
				"-dir",
				"/migrations/regional",
				"postgres",
				"postgres://vetchium:${DB_PASSWORD}@regional-db-usa1:5432/vetchium_usa1?sslmode=disable",
				"up"
			]
		},
		"migrate-deu1": {
			"image": "ghcr.io/vetchium/migrate:${STAGING_TAG:-staging}",
			"depends_on": { "regional-db-deu1": { "condition": "service_healthy" } },
			"command": [
				"-dir",
				"/migrations/regional",
				"postgres",
				"postgres://vetchium:${DB_PASSWORD}@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"up"
			]
		},
		"bootstrap-admin": {
			"image": "postgres:17-alpine",
			"depends_on": {
				"global-db": { "condition": "service_healthy" },
				"migrate-global": { "condition": "service_completed_successfully" }
			},
			"environment": {
				"STAGING_ADMIN_EMAIL": "${STAGING_ADMIN_EMAIL:?set STAGING_ADMIN_EMAIL in staging/.env}",
				"STAGING_ADMIN_PASSWORD": "${STAGING_ADMIN_PASSWORD:?set STAGING_ADMIN_PASSWORD in staging/.env}"
			},
			"volumes": [
				{ "type": "bind", "source": "./bootstrap", "target": "/bootstrap" }
			],
			"entrypoint": ["sh", "-c"],
			"command": [
				"psql 'postgres://vetchium:${DB_PASSWORD}@global-db:5432/vetchium_global?sslmode=disable' -v ON_ERROR_STOP=1 -v admin_email=\"$$STAGING_ADMIN_EMAIL\" -v admin_password=\"$$STAGING_ADMIN_PASSWORD\" -f /bootstrap/admin.sql"
			]
		},
		"global-service": {
			"image": "ghcr.io/vetchium/global-service:${STAGING_TAG:-staging}",
			"depends_on": {
				"bootstrap-admin": { "condition": "service_completed_successfully" },
				"mailpit": { "condition": "service_started" },
				"garage-init-ind1": { "condition": "service_completed_successfully" }
			},
			"environment": {
				"ENV": "STAGING",
				"LOG_LEVEL": "INFO",
				"GLOBAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@global-db:5432/vetchium_global?sslmode=disable",
				"IND1_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-ind1:5432/vetchium_ind1?sslmode=disable",
				"USA1_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-usa1:5432/vetchium_usa1?sslmode=disable",
				"DEU1_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"ADMIN_TFA_TOKEN_CLEANUP_INTERVAL": "1m",
				"ADMIN_SESSION_CLEANUP_INTERVAL": "1m",
				"HUB_SIGNUP_TOKEN_CLEANUP_INTERVAL": "1m",
				"ORG_SIGNUP_TOKEN_CLEANUP_INTERVAL": "1m",
				"SMTP_HOST": "mailpit",
				"SMTP_PORT": "1025",
				"SMTP_FROM_ADDRESS": "${SMTP_FROM_ADDRESS:-noreply@vetchium.com}",
				"SMTP_FROM_NAME": "${SMTP_FROM_NAME:-Vetchium}",
				"EMAIL_WORKER_POLL_INTERVAL": "10s",
				"ADMIN_TFA_TOKEN_EXPIRY": "10m",
				"ADMIN_SESSION_TOKEN_EXPIRY": "24h",
				"ADMIN_INVITATION_TOKEN_EXPIRY": "168h",
				"ADMIN_PASSWORD_RESET_TOKEN_EXPIRY": "1h",
				"ADMIN_PASSWORD_RESET_TOKEN_CLEANUP_INTERVAL": "1h",
				"ADMIN_UI_URL": "https://admin-staging.vetchium.com",
				"CORS_ALLOWED_ORIGINS": "https://admin-staging.vetchium.com",
				"GLOBAL_S3_ENDPOINT": "http://garage-ind1:3900",
				"GLOBAL_S3_BUCKET": "vetchium-global",
				"GLOBAL_S3_REGION": "us-east-1",
				"GLOBAL_S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID}",
				"GLOBAL_S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY}"
			},
			"healthcheck": {
				"test": ["CMD-SHELL", "nc -z localhost 8081 || exit 1"],
				"interval": "10s",
				"timeout": "5s",
				"retries": 5
			}
		},
		"regional-api-server-ind1": {
			"image": "ghcr.io/vetchium/regional-api-server:${STAGING_TAG:-staging}",
			"depends_on": {
				"migrate-global": { "condition": "service_completed_successfully" },
				"migrate-ind1": { "condition": "service_completed_successfully" },
				"migrate-usa1": { "condition": "service_completed_successfully" },
				"migrate-deu1": { "condition": "service_completed_successfully" },
				"garage-init-ind1": { "condition": "service_completed_successfully" },
				"garage-init-usa1": { "condition": "service_completed_successfully" },
				"garage-init-deu1": { "condition": "service_completed_successfully" }
			},
			"environment": {
				"REGION": "ind1",
				"ENV": "STAGING",
				"LOG_LEVEL": "INFO",
				"GLOBAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@global-db:5432/vetchium_global?sslmode=disable",
				"REGIONAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-ind1:5432/vetchium_ind1?sslmode=disable",
				"REGIONAL_DB_CONN_IND1": "postgres://vetchium:${DB_PASSWORD}@regional-db-ind1:5432/vetchium_ind1?sslmode=disable",
				"REGIONAL_DB_CONN_USA1": "postgres://vetchium:${DB_PASSWORD}@regional-db-usa1:5432/vetchium_usa1?sslmode=disable",
				"REGIONAL_DB_CONN_DEU1": "postgres://vetchium:${DB_PASSWORD}@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"S3_ENDPOINT_IND1": "http://garage-ind1:3900",
				"S3_ENDPOINT_USA1": "http://garage-usa1:3900",
				"S3_ENDPOINT_DEU1": "http://garage-deu1:3900",
				"S3_BUCKET_IND1": "vetchium-ind1",
				"S3_BUCKET_USA1": "vetchium-usa1",
				"S3_BUCKET_DEU1": "vetchium-deu1",
				"S3_REGION_IND1": "us-east-1",
				"S3_REGION_USA1": "us-east-1",
				"S3_REGION_DEU1": "us-east-1",
				"S3_ACCESS_KEY_ID_IND1": "${S3_ACCESS_KEY_ID}",
				"S3_ACCESS_KEY_ID_USA1": "${S3_ACCESS_KEY_ID}",
				"S3_ACCESS_KEY_ID_DEU1": "${S3_ACCESS_KEY_ID}",
				"S3_SECRET_ACCESS_KEY_IND1": "${S3_SECRET_ACCESS_KEY}",
				"S3_SECRET_ACCESS_KEY_USA1": "${S3_SECRET_ACCESS_KEY}",
				"S3_SECRET_ACCESS_KEY_DEU1": "${S3_SECRET_ACCESS_KEY}",
				"GLOBAL_S3_ENDPOINT": "http://garage-ind1:3900",
				"GLOBAL_S3_BUCKET": "vetchium-global",
				"GLOBAL_S3_REGION": "us-east-1",
				"GLOBAL_S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID}",
				"GLOBAL_S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY}",
				"ORG_TFA_TOKEN_EXPIRY": "10m",
				"ORG_SESSION_TOKEN_EXPIRY": "24h",
				"ORG_SIGNUP_TOKEN_EXPIRY": "24h",
				"ORG_REMEMBER_ME_EXPIRY": "8760h"
			},
			"healthcheck": {
				"test": ["CMD-SHELL", "nc -z localhost 8080 || exit 1"],
				"interval": "10s",
				"timeout": "5s",
				"retries": 5
			}
		},
		"regional-api-server-usa1": {
			"image": "ghcr.io/vetchium/regional-api-server:${STAGING_TAG:-staging}",
			"depends_on": {
				"migrate-global": { "condition": "service_completed_successfully" },
