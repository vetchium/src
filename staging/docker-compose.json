				"REGIONAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-usa1:5432/vetchium_usa1?sslmode=disable",
				"SMTP_HOST": "mailpit",
				"SMTP_PORT": "1025",
				"SMTP_FROM_ADDRESS": "${SMTP_FROM_ADDRESS:-noreply@vetchium.com}",
				"SMTP_FROM_NAME": "${SMTP_FROM_NAME:-Vetchium}",
				"EMAIL_WORKER_POLL_INTERVAL": "10s",
				"ORG_TFA_TOKEN_CLEANUP_INTERVAL": "1h",
				"ORG_SESSION_CLEANUP_INTERVAL": "1h"
			}
		},
		"regional-worker-deu1": {
			"image": "ghcr.io/vetchium/regional-worker:${STAGING_TAG:-staging}",
			"depends_on": {
				"migrate-deu1": { "condition": "service_completed_successfully" }
			},
			"environment": {
				"REGION": "deu1",
				"LOG_LEVEL": "INFO",
				"REGIONAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"SMTP_HOST": "mailpit",
				"SMTP_PORT": "1025",
				"SMTP_FROM_ADDRESS": "${SMTP_FROM_ADDRESS:-noreply@vetchium.com}",
				"SMTP_FROM_NAME": "${SMTP_FROM_NAME:-Vetchium}",
				"EMAIL_WORKER_POLL_INTERVAL": "10s",
				"ORG_TFA_TOKEN_CLEANUP_INTERVAL": "1h",
				"ORG_SESSION_CLEANUP_INTERVAL": "1h"
			}
		},
		"vm-global": {
			"image": "nginx:alpine",
			"volumes": ["./nginx/global-vm.conf:/etc/nginx/nginx.conf:ro"],
			"ports": ["8091:80"],
			"depends_on": { "global-service": { "condition": "service_healthy" } },
			"healthcheck": {
				"test": ["CMD-SHELL", "wget -qO- http://127.0.0.1/health || exit 1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"vm-ind1": {
			"image": "nginx:alpine",
			"volumes": ["./nginx/ind1-vm.conf:/etc/nginx/nginx.conf:ro"],
			"ports": ["8092:80"],
			"depends_on": {
				"regional-api-server-ind1": { "condition": "service_healthy" }
			},
			"healthcheck": {
				"test": ["CMD-SHELL", "wget -qO- http://127.0.0.1/health || exit 1"],
				"interval": "5s",
				"timeout": "5s",
				"retries": 10
			}
		},
		"vm-usa1": {
			"image": "nginx:alpine",
			"volumes": ["./nginx/usa1-vm.conf:/etc/nginx/nginx.conf:ro"],
			"ports": ["8093:80"],
			"depends_on": {
