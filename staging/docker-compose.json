				"REGIONAL_DB_CONN": "postgres://vetchium:${DB_PASSWORD}@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"SMTP_HOST": "mailserver",
				"SMTP_PORT": "25",
				"SMTP_FROM_ADDRESS": "${SMTP_FROM_ADDRESS:-noreply@vetchium.com}",
				"SMTP_FROM_NAME": "${SMTP_FROM_NAME:-Vetchium}",
				"EMAIL_WORKER_POLL_INTERVAL": "10s",
				"ORG_TFA_TOKEN_CLEANUP_INTERVAL": "1h",
				"ORG_SESSION_CLEANUP_INTERVAL": "1h"
			}
		},
		"vm-global": {
			"image": "nginx:alpine",
			"volumes": ["./nginx/global-vm.conf:/etc/nginx/nginx.conf:ro"],
			"ports": ["8091:80"],
			"depends_on": { "global-service": { "condition": "service_healthy" } },
