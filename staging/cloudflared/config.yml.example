# Example of the cloudflared ingress map for Vetchium staging.
#
# Do NOT edit this file directly — run staging/cloudflared/setup-tunnel.sh, which
# creates the named tunnel, adds the DNS routes, and generates the real
# config.yml (with the tunnel UUID + credentials-file path filled in).
#
# This is checked in only to document the hostname -> host-port mapping. The
# cloudflared daemon runs on the host (Homebrew install) and reaches each
# container via its published host port, so the request path is:
#
#   browser -> Cloudflare edge (TLS) -> cloudflared (host) -> nginx VM -> app
#
# which is identical to production minus the (disposable) Cloudflare edge.

tunnel: <UUID-filled-in-by-setup-script>
credentials-file: /Users/<you>/.cloudflared/<UUID>.json

ingress:
  # ── Per-VM direct addressing (verify each region/global in isolation) ──
  - hostname: global-staging.vetchium.com # global VM  -> vm-global  (admin + global API)
    service: http://localhost:8091
  - hostname: in-staging.vetchium.com # ind1 VM    -> vm-ind1
    service: http://localhost:8092
  - hostname: us-staging.vetchium.com # usa1 VM    -> vm-usa1
    service: http://localhost:8093
  - hostname: de-staging.vetchium.com # deu1 VM    -> vm-deu1
    service: http://localhost:8094

  # ── Prod-shaped app entry points (what the UIs call) ──
  - hostname: api-staging.vetchium.com # "nearest regional VM" stand-in (-> ind1)
    service: http://localhost:8092

  # ── UIs ──
  - hostname: hub-staging.vetchium.com # hub-ui   (API -> api.staging)
    service: http://localhost:8095
  - hostname: org-staging.vetchium.com # org-ui   (API -> api.staging)
    service: http://localhost:8096
  - hostname: admin-staging.vetchium.com # admin-ui (API -> global.staging)
    service: http://localhost:8097

  # ── Catch-all ──
  - service: http_status:404
