		"seed-users": {
			"image": "oven/bun:1",
			"volumes": [
				{
					"source": "./api-server/db/dev-seed",
					"target": "/seed",
					"type": "bind"
				}
			],
			"command": ["bun", "run", "/seed/seed-users.ts"],
			"depends_on": {
				"api-lb": {
					"condition": "service_healthy"
				},
				"seed-global": {
					"condition": "service_completed_successfully"
				},
				"regional-worker-ind1": {
					"condition": "service_started"
				},
				"regional-worker-usa1": {
					"condition": "service_started"
				},
				"regional-worker-deu1": {
					"condition": "service_started"
				},
				"mailpit": {
					"condition": "service_started"
				}
			}
		},
		"global-service": {
			"build": {
				"context": ".",
				"dockerfile": "api-server/Dockerfile.global-service"
			},
			"depends_on": {
				"seed-global": {
					"condition": "service_completed_successfully"
				},
				"mailpit": {
					"condition": "service_started"
				},
				"garage-init-ind1": {
					"condition": "service_completed_successfully"
				}
			},
			"environment": {
				"LOG_LEVEL": "DEBUG",
				"GLOBAL_DB_CONN": "postgres://vetchium:vetchium_dev@global-db:5432/vetchium_global?sslmode=disable",
				"IND1_DB_CONN": "postgres://vetchium:vetchium_dev@regional-db-ind1:5432/vetchium_ind1?sslmode=disable",
				"USA1_DB_CONN": "postgres://vetchium:vetchium_dev@regional-db-usa1:5432/vetchium_usa1?sslmode=disable",
				"DEU1_DB_CONN": "postgres://vetchium:vetchium_dev@regional-db-deu1:5432/vetchium_deu1?sslmode=disable",
				"ADMIN_TFA_TOKEN_CLEANUP_INTERVAL": "1m",
				"ADMIN_SESSION_CLEANUP_INTERVAL": "1m",
				"HUB_SIGNUP_TOKEN_CLEANUP_INTERVAL": "1m",
				"ORG_SIGNUP_TOKEN_CLEANUP_INTERVAL": "1m",
				"SMTP_HOST": "mailpit",
				"SMTP_PORT": "1025",
				"SMTP_FROM_ADDRESS": "noreply@vetchium.com",
				"SMTP_FROM_NAME": "Vetchium",
				"EMAIL_WORKER_POLL_INTERVAL": "10s",
				"ADMIN_TFA_TOKEN_EXPIRY": "10m",
				"ADMIN_SESSION_TOKEN_EXPIRY": "24h",
				"ADMIN_INVITATION_TOKEN_EXPIRY": "168h",
				"ADMIN_PASSWORD_RESET_TOKEN_EXPIRY": "1h",
				"ADMIN_PASSWORD_RESET_TOKEN_CLEANUP_INTERVAL": "1h",
				"ADMIN_UI_URL": "http://localhost:3001",
				"CORS_ALLOWED_ORIGINS": "*",
				"GLOBAL_S3_ENDPOINT": "http://garage-ind1:3900",
				"GLOBAL_S3_BUCKET": "vetchium-global",
				"GLOBAL_S3_REGION": "us-east-1",
				"GLOBAL_S3_ACCESS_KEY_ID": "GK1234567890abcdef12345678",
				"GLOBAL_S3_SECRET_ACCESS_KEY": "1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
			},
			"healthcheck": {
				"test": ["CMD-SHELL", "nc -z localhost 8081 || exit 1"],
				"interval": "10s",
				"timeout": "5s",
				"retries": 5
			}
		},
